  (() => {
    let utmTrackingStr = '';
    let showingUTM = utmTrackingStr === '' ? true : false;
    if (utmTrackingStr && utmTrackingStr !== '') {
      for (const utmKey of utmTrackingStr.split(' ')) {
        if (window.location.search.includes(utmKey)) {
          showingUTM = true;
          break;
        }
      }
