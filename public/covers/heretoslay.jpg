<script>
document.addEventListener("DOMContentLoaded", () => {
  const accordionsHeadings = document.querySelectorAll(".footer-accordion-heading");
  accordionsHeadings.forEach(header => {
    header.addEventListener("click", () => {
      const expanded = header.getAttribute("aria-expanded") === "true";

      // close all first (optional: remove if you want multiple open)
      document.querySelectorAll(".footer-accordion-heading").forEach(h => {
        h.setAttribute("aria-expanded", "false");
        h.classList.remove("footer-accordion-open");
        h.nextElementSibling.classList.remove("footer-accordion-open");
      });

      // toggle clicked one
      if (!expanded) {
        header.setAttribute("aria-expanded", "true");
        header.classList.add("footer-accordion-open");
        header.nextElementSibling.classList.add("footer-accordion-open");
      }
    });
  });
});
</script>



