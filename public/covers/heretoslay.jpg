    let showingDoesNotContain = true;
    const doesNotContainStr = '';
    if (doesNotContainStr && doesNotContainStr !== '') {
      for (const doesNotContainKey of doesNotContainStr.split(' ')) {
        if (window.location.search.includes(doesNotContainKey)) {
          showingDoesNotContain = false;
          break;
        }
      }
    }
    if (showingUTM && showingDoesNotContain) {
      document.getElementById('template--26708144914738__featured_collection_3K6Rtm')?.classList.remove('hidden');
    } else {
      document.getElementById('template--26708144914738__featured_collection_3K6Rtm')?.classList.add('hidden');
    }
  })();
</script>

  



