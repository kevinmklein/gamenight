<script>
      document.addEventListener('DOMContentLoaded', () => {
        function applyDynamicHeight(img) {
          const naturalW = img.naturalWidth;
          const naturalH = img.naturalHeight;

          if (naturalW && naturalH) {
            // Read existing width or fallback to natural width
            const appliedWidth = img.getAttribute('width') || img.clientWidth || naturalW;

            // Calculate height based on ratio
            const calculatedHeight = (appliedWidth / naturalW) * naturalH;

            img.style.width = appliedWidth + 'px';
            img.style.height = calculatedHeight + 'px';
            img.style.aspectRatio = `${naturalW} / ${naturalH}`;
            img.style.objectFit = 'contain';
          }
        }

        const observer = new MutationObserver(() => {
          document
            .querySelectorAll('img.sc-hKgILt, img.gTLZXx') // include roulette class too
            .forEach((img) => {
              if (!img.dataset.heightApplied) {
                if (img.complete) {
                  applyDynamicHeight(img);
                } else {
                  img.addEventListener('load', () => applyDynamicHeight(img));
                }
                img.dataset.heightApplied = 'true';
              }
            });
        });

        observer.observe(document.body, { childList: true, subtree: true });
      });
    </script>
  
    

    
    <script>
      (() => {
